{
  "name": "Bubbles",
  "description": "Floating colorful bubbles :D.",
  "shader_path": "assets/shaders/bubbles.glsl",
  "variables": {
    "speed": {
      "type": "float",
      "default": 1.0,
      "min": 0.1,
      "max": 5.0,
      "description": "Animation speed"
    },
    "count": {
      "type": "float",
      "default": 20.0,
      "min": 5.0,
      "max": 40.0,
      "description": "Number of bubbles"
    },
    "color1": {
      "type": "color",
      "default": "#F04D00",
      "description": "Primary bubble color"
    },
    "color2": {
      "type": "color",
      "default": "#1A66CC",
      "description": "Secondary bubble color"
    },
    "color3": {
      "type": "color",
      "default": "#CC1A66",
      "description": "Tertiary bubble color"
    }
  },
  "credit": "https://www.shadertoy.com/view/4dl3zn"
}
